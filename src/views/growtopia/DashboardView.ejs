<!DOCTYPE html>
<html lang="en" style="background-color: rgba(0,0,0,0.0); width:100%; height: 100%;">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Growtopia Player Support</title>
    <link rel="icon" type="image/png"
        href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/images/growtopia.ico"
        sizes="16x16" />
    <link rel="shortcut icon"
        href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/images/growtopia.ico"
        type="image/x-icon">
    <link rel="icon"
        href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/images/growtopia.ico"
        type="image/x-icon">
    <!-- include bootstrap and custom  css -->
    <link media="all" rel="stylesheet"
        href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/css/faq-main.css">
    <!-- include custom  css -->
    <link media="all" rel="stylesheet"
        href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/css/shop-custom.css">
    <link media="all" rel="stylesheet"
        href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/css/ingame-custom.css">
    <style>
        .modal-backdrop {
            background-color: rgba(0, 0, 0, 0.1);
            !important
        }

        .modal-backdrop+div {
            overflow: auto;
        }

        .modal-body,
        .content {
            padding: 0;
        }

        .hidden {
            display: none;
        }

        .page-hidden {
            display: none !important;
        }
    </style>
</head>

<body style="background-color: rgba(0,0,0,0.0);">
    <button type="button" class="btn btn-primary hidden" data-toggle="modal" id="modalButton" data-target="#modalShow"
        data-backdrop="static" data-keyboard="false"></button>
    <div class="content">
        <section class="common-box ">
            <div class="container">
                <div class="row">
                    <div class="col-md-12 col-sm-12">
                        <div class="row">
                            <div class="modal fade product-list-popup" id="modalShow" tabindex="-1" role="dialog"
                                aria-hidden="false">
                                <div class="modal-dialog modal-dialog-centered" role="document">
                                    <div class="modal-content">

                                        <!-- LOGIN PAGE -->
                                        <div class="modal-body" id="loginPage">
                                            <div class="content">
                                                <section class="common-box ">
                                                    <div class="container">
                                                        <div class="section-title center-align">
                                                            <h2>Log in with your KeyTopia ID</h2>
                                                        </div>
                                                        <div class="row div-content-center">
                                                            <div class="col-md-12 col-sm-12">
                                                                <form method="POST"
                                                                    action="https://login.creativeps.eu/player/growid/login/validate"
                                                                    accept-charset="UTF-8" class="" role="form"
                                                                    required="required" autocomplete="off"><input
                                                                        name="_token" type="hidden"
                                                                        value="">
                                                                    <div class="form-group">
                                                                        <label for="server-select">Select Server:</label>
                                                                        <select id="server-select"
                                                                            class="form-control grow-text"
                                                                            name="server" required>
                                                                            <option value="">Choose Server</option>
                                                                            <option value="us">US Server</option>
                                                                            <option value="eu">EU Server</option>
                                                                            <option value="asia">Asia Server</option>
                                                                        </select>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <input id="login-name"
                                                                            class="form-control grow-text"
                                                                            placeholder="Your KeyTopia Name"
                                                                            name="growId" type="text">
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <input id="password"
                                                                            class="form-control grow-text"
                                                                            placeholder="Your KeyTopia Password"
                                                                            name="password" type="password" value="">
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <small>Create account? Enter Name without
                                                                            Password & Log In!</small>
                                                                    </div>
                                                                    <div class="form-group text-center forgot-password">
                                                                        <a href="javascript:void(0);" onclick="showSupportPage()">Page
                                                                            Support!</a>
                                                                    </div>
                                                                    <div class="form-group text-center">
                                                                        <input id="submit-btn"
                                                                            class="btn btn-lg btn-primary grow-button"
                                                                            type="submit" value="Register" disabled>
                                                                    </div>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>

                                        <!-- SUPPORT PAGE -->
                                        <div class="modal-body page-hidden" id="supportPage">
                                            <div class="content">
                                                <section class="common-box ">
                                                    <div class="container">
                                                        <div class="section-title center-align">
                                                            <h2>Need Help or have problem?</h2>
                                                            <p><strong>Customer Service</strong></p>
                                                        </div>
                                                        <div class="row div-content-center">
                                                            <div class="col-md-12 col-sm-12">
                                                                <div class="form-group">
                                                                    <small>Discord serves as the primary and fastest support channel for our Growtopia private server. Kindly open a ticket in #support Discord channel for any assistance.</small>
                                                                </div>
                                                                <div class="form-group text-center" style="margin-top: 30px;">
                                                                    <a href="https://discord.gg/H9HBJvD8UH" target="_blank" class="btn btn-lg btn-primary grow-button" style="background-color: #5865f2; display: inline-block; padding: 10px 40px; margin: 5px;">
                                                                        🔗 Discord Support
                                                                    </a>
                                                                </div>
                                                                <div class="form-group text-center">
                                                                    <a href="https://chat.whatsapp.com/D0Uf6uwXwE15xGPjkgW80F?mode=gi_t" target="_blank" class="btn btn-lg btn-primary grow-button" style="background-color: #25d366; display: inline-block; padding: 10px 40px; margin: 5px;">
                                                                        💬 WhatsApp
                                                                    </a>
                                                                </div>
                                                                <div class="form-group text-center" style="margin-top: 20px;">
                                                                    <input type="button" onclick="showLoginPage()" class="btn btn-lg btn-primary grow-button" value="← BACK" style="display: inline-block; padding: 10px 40px;">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
<script defer src="https://static.cloudflareinsights.com/beacon.min.js/v8c78df7c7c0f484497ecbca7046644da1771523124516" integrity="sha512-8DS7rgIrAmghBFwoOTujcf6D9rXvH8xm8JQ1Ja01h9QX8EzXldiszufYa4IFfKdLUKTTrnSFXLDkUEOTrZQ8Qg==" data-cf-beacon='{"version":"2024.11.0","token":"1c06da9067b74d96a312ca9ca1adb11c","r":1,"server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>
</body>
<!-- JQUERY LIBRARY -->
<script
    src="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/vendors/jquery/jquery-2.1.4.min.js"></script>
<!-- boostrap javascript -->
<script
    src="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/vendors/bootstrap/javascripts/bootstrap.min.js"></script>
<script>
    let clicked = false;
    
    function showLoginPage() {
        $('#loginPage').removeClass('page-hidden');
        $('#supportPage').addClass('page-hidden');
    }

    function showSupportPage() {
        $('#loginPage').addClass('page-hidden');
        $('#supportPage').removeClass('page-hidden');
    }

    function validateForm() {
        const serverSelect = $('#server-select').val();

        // Tombol hanya enable jika server dipilih
        if (serverSelect !== '') {
            $('#submit-btn').prop('disabled', false);
        } else {
            $('#submit-btn').prop('disabled', true);
        }
    }

    $("a").click(function () { if (clicked === false) { clicked = true; return true; } $(this).attr("onclick", "return false;"); });
    $('document').ready(function () {
        document.onkeydown = (e) => {
            if (e.key == 123) {
                e.preventDefault();
            }
            if (e.key == 'F12') {
                e.preventDefault();
            }
            if (e.ctrlKey && e.shiftKey && e.key == 'I') {
                e.preventDefault();
            }
            if (e.ctrlKey && e.key == 'I') {
                e.preventDefault();
            }
            if (e.ctrlKey && e.shiftKey && e.key == 'C') {
                e.preventDefault();
            }
            if (e.ctrlKey && e.shiftKey && e.key == 'J') {
                e.preventDefault();
            }
            if (e.ctrlKey && e.key == 'U') {
                e.preventDefault();
            }
        };
        $('#modalButton').trigger('click');
        $('.close').on('click', function () {
            window.location = "https://login.creativeps.eu/player/validate/close"
        });

        $('#password, #login-name').on('input change', function () {
            if ($('#password').val().length > 0 && $('#login-name').val().length > 0) {
                $('#submit-btn').val('Log in');
            } else {
                $('#submit-btn').val('Register/Log in');
            }
        });
        $('#submit-btn').val($('#password').val().length > 0 && $('#login-name').val().length > 0 ? 'Log in' : 'Register/Log in');

        // Validasi saat server berubah
        $('#server-select').on('change', function () {
            validateForm();
        });

        $('form').on('submit', function() {
            if ($('#login-name').val().length === 0 && $('#password').val().length === 0) {
                $('<input>').attr({
                    type: 'hidden',
                    name: 'growId',
                    value: 'Guest'
                }).appendTo(this);
                $('#login-name').removeAttr('name');
            } else if ($('#login-name').val().length === 0) {
                $('<input>').attr({
                    type: 'hidden',
                    name: 'growId',
                    value: 'Guest'
                }).appendTo(this);
                $('#login-name').removeAttr('name');
            }
        });

        // Initialize button state
        validateForm();

        var observer = new MutationObserver(function (mutations) {
            mutations.forEach(function (mutation) {
                for (var i = 0; i < mutation.addedNodes.length; i++) {
                    if (mutation.addedNodes[i].tagName == 'DIV') {
                        var thediv = mutation.addedNodes[i];
                        var sw = window.screen.width;
                        if (sw < 667) {
                            $(thediv).css({
                                'transform': 'scale(0.75)',
                                'transform-origin': '0 0',
                                '-webkit-transform': 'scale(0.75)',
                                '-webkit-transform-origin': '0 0',
                                'overflow': 'auto'
                            });
                        }
                    }
                }
            });
        });
        observer.observe(document.body, { attributes: false, childList: true, characterData: false });
    });
</script>

</html>
